{
  "name": "ilia-fintech-challenge",
  "version": "1.0.0",
  "description": "Digital wallet microservices — ília FinTech Challenge",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"npm run dev:users\" \"npm run dev:wallet\"",
    "dev:users": "tsx watch src/ms-users/server.ts",
    "dev:wallet": "tsx watch src/ms-wallet/server.ts",
    "start": "npm run build && concurrently \"node dist/ms-users/server.js\" \"node dist/ms-wallet/server.js\"",
    "start:users": "npm run build && node dist/ms-users/server.js",
    "start:wallet": "npm run build && node dist/ms-wallet/server.js",
    "db:create": "tsx --env-file=.env ./scripts/create-database.ts",
    "db:drop": "tsx --env-file=.env ./scripts/drop-database.ts",
    "db:migrate": "tsx --env-file=.env ./scripts/migrate.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/env": "^5.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@sinclair/typebox": "^0.34.41",
    "close-with-grace": "^2.2.0",
    "concurrently": "^9.2.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "knex": "^3.1.0",
    "mysql2": "^3.15.0",
    "postgrator": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "fastify-tsconfig": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
